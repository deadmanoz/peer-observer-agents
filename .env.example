# Required
ANNOTATION_AGENT_GRAFANA_API_KEY=your-grafana-service-account-token
ANNOTATION_AGENT_MCP_CONFIG=/path/to/mcp-config.json

# Optional (defaults shown)
# ANNOTATION_AGENT_LISTEN_ADDR=127.0.0.1:9099
# ANNOTATION_AGENT_GRAFANA_URL=http://127.0.0.1:9321
# ANNOTATION_AGENT_CLAUDE_BIN=claude
# ANNOTATION_AGENT_CLAUDE_MODEL=claude-sonnet-4-6
# ANNOTATION_AGENT_LOG_FILE=/var/log/annotation-agent.log
# ANNOTATION_AGENT_HTTP_TIMEOUT_SECS=30
# ANNOTATION_AGENT_CLAUDE_TIMEOUT_SECS=600

# Logging (tracing-subscriber EnvFilter)
# RUST_LOG=peer_observer_agent=info
